<!DOCTYPE html>
<html>
  <head>
    <title>Weebi</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
      <div class="container-fluid">
        <%= link_to root_path, class: 'navbar-brand px-2' do %>
          <img src="https://www.weebi.com/images/Weebi_Logo_Full.png" alt="Weebi" width="130" height="35">
        <% end %>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
            <% if user_signed_in? %>
              <li class="nav-item">
                <%= link_to "Admin", rails_admin_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Import", new_import_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Jobs", mission_control_jobs_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to current_user.email, root_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Déconnexion", destroy_user_session_path, method: :delete, class: "nav-link text-danger" %>
              </li>
            <% end %>
          </ul>
        </div>
      </div>
    </nav>
    <div class="main-hero">
      <%= yield %>
    </div>
  </body>
</html>
