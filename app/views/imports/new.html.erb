<div class="container py-5">
  <div class="card">
    <div class="card-header mb-2">
      Import Data
    </div>
    <div class="card-body">
      <%= form_with(model: ImportFile.new, url: imports_path, local: true, html: { multipart: true }) do |form| %>
        <div class="form-group mb-4">
          <%= form.country_select :country, { include_blank: 'Select a country' }, { class: 'form-select' } %>
        </div>
        <div class="form-group">
          <%= form.file_field :file, class: 'form-control' %>
        </div>
        <%= form.submit 'Upload', class: 'btn btn-primary my-3' %>
      <% end %>
    </div>
  </div>
</div>
